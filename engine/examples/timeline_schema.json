{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Engine timeline",
  "type": "object",
  "required": ["metadata", "frames"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["engine_version", "start_time", "sim_until", "sample_dt"],
      "properties": {
        "engine_version": {"type": "string"},
        "seed": {"type": ["integer", "null"]},
        "start_time": {"type": "number"},
        "sim_until": {"type": "number"},
        "sample_dt": {"type": "number"}
      }
    },
    "frames": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["t", "actor_states"],
        "properties": {
          "t": {"type": "number"},
          "actor_states": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "pos"],
              "properties": {
                "id": {"type": "string"},
                "pos": {
                  "type": "array",
                  "items": {"type": "number"},
                  "minItems": 3,
                  "maxItems": 3
                },
                "rot": {
                  "type": "array",
                  "items": {"type": "number"}
                },
                "metadata": {"type": ["object", "null"]}
              }
            }
          }
        }
      }
    }
  }
}
